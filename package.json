{
  "name": "@openclaw/my-plugin",
  "version": "1.0.0",
  "description": "Custom memory management plugin for OpenClaw",
  "type": "module",
  "main": "./index.ts",
  "dependencies": {
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "openclaw": ">=2026.4.1",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.1"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "compat": {
      "pluginApi": ">=2026.4.1",
      "minGatewayVersion": "2026.4.1"
    },
    "build": {
      "openclawVersion": "2026.4.1",
      "pluginSdkVersion": "2026.4.1"
    }
  }
}
